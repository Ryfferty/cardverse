      "description": "Ace of Spades",
      "count": 1,
      "tags": [],
      "effects": [],
      "suit": "spades",
      "number": "A"
    },
    {
      "id": "ace_hearts",
      "name": "A♥",
      "category": "basic",
      "description": "Ace of Hearts",
      "count": 1,
      "tags": [],
      "effects": [],
      "suit": "hearts",
      "number": "A"
    },
    {
      "id": "ace_diamonds",
      "name": "A♦",
      "category": "basic",
      "description": "Ace of Diamonds",
      "count": 1,
      "tags": [],
      "effects": [],
      "suit": "diamonds",
      "number": "A"
    },
    {
      "id": "ace_clubs",
      "name": "A♣",
      "category": "basic",
      "description": "Ace of Clubs",
      "count": 1,
      "tags": [],
      "effects": [],
      "suit": "clubs",
      "number": "A"
    },
    {
      "id": "two_spades",
      "name": "2♠",
      "category": "basic",
      "description": "2 of Spades",
