{
  "manifest": {
    "id": "test-poker-basic",
    "name": "Test Poker Basic Cards",
    "version": "1.0.0",
    "author": "CardVerse Developer",
    "description": "Standard 52-card poker deck",
    "minPlayers": 2,
    "maxPlayers": 6,
    "frameworkVersion": "1.0.0",
    "tags": ["poker", "basic", "standard"]
  },
  "rules": {
    "zones": [
      { "id": "deck", "name": "Deck", "visibility": "none", "ordered": true, "faceDown": true, "owner": "global" },
      { "id": "hand", "name": "Hand", "visibility": "owner", "ordered": false, "faceDown": false, "owner": "player", "capacity": 5 },
      { "id": "discard", "name": "Discard Pile", "visibility": "all", "ordered": false, "faceDown": true, "owner": "global" }
    ],
    "phases": [
      { "id": "deal", "auto": true },
      { "id": "bet", "auto": false },
      { "id": "draw", "auto": false },
      { "id": "showdown", "auto": true }
    ],
    "resources": [
      { "id": "chips", "name": "Chips", "defaultValue": 100, "minValue": 0 }
    ],
    "turnOrder": "counterclockwise"
  },
  "cards": [
