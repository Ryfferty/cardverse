{
  "manifest": {
    "id": "sanguosha-standard",
    "name": "三国杀标准版",
    "version": "1.0.0",
    "author": "CardVerse",
    "description": "三国杀标准版完整游戏定义，包含58张基本牌、28张锦囊牌、21张装备牌和10名武将",
    "minPlayers": 2,
    "maxPlayers": 8,
    "frameworkVersion": "1.0.0",
    "tags": ["sanguosha", "standard", "card-game", "strategy"]
  },
  "cardPacks": [
    { "type": "basic", "source": "cards/basic.json" },
    { "type": "trick", "source": "cards/trick.json" },
    { "type": "equipment", "source": "cards/equipment.json" }
  ],
  "characterPack": {
    "source": "characters/characters.json"
  },
  "rules": {
    "source": "rules.json"
  },
  "winConditions": [
    { "type": "lord-victory", "description": "主公阵营胜利：所有反贼和内奸阵亡时，主公和忠臣获胜" },
    { "type": "rebel-victory", "description": "反贼胜利：主公阵亡时，所有反贼立即获胜" },
    { "type": "spy-victory", "description": "内奸单挑胜利：主公阵亡后，内奸为最后存活的角色" },
    { "type": "last-standing", "description": "常规胜利：场上只剩一名角色存活时，该角色获胜" }
  ],
  "drawConditions": [
    { "type": "all-dead", "description": "当所有角色都阵亡时游戏平局" },
    { "type": "deck-empty", "description": "当牌堆用尽且无法继续游戏时平局" }
  ],
  "effects": {
    "scripts": [
      "effects/sha.ts",
      "effects/shan.ts",
      "effects/tao.ts",
      "effects/jiu.ts",
      "effects/guohe.ts",
      "effects/shunshou.ts",
      "effects/wuzhong.ts",
      "effects/wuxie.ts",
      "effects/juedou.ts",
      "effects/nanman.ts",
      "effects/wanjian.ts",
      "effects/taoyuan.ts",
      "effects/zhugeliannu.ts",
      "effects/qinggang.ts",
      "effects/cixiong.ts",
      "effects/zhangba.ts",
      "effects/guanshi.ts",
      "effects/fangtian.ts",
      "effects/qinglong.ts",
      "effects/qilin.ts",
      "effects/bagua.ts",
      "effects/renwang.ts",
      "effects/baiyin.ts",
      "effects/tengjia.ts",
      "effects/plus1horse.ts",
      "effects/minus1horse.ts",
      "effects/caocao.ts",
      "effects/liubei.ts",
      "effects/sunquan.ts",
      "effects/guanyu.ts",
      "effects/zhangfei.ts",
      "effects/zhaoyun.ts",
      "effects/lvbu.ts",
      "effects/diaochan.ts",
      "effects/huatuo.ts",
      "effects/simayi.ts"
    ]
  }
}